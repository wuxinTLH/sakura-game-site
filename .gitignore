# ========================================
# 桜游戏屋 .gitignore
# ========================================

# 依赖
node_modules/
logs/*.log
.env
npm-debug.log*
.pnp
.pnp.js

# 构建产物
dist/
dist-ssr/
build/
``
# 环境变量（含敏感信息，绝不提交）
.env
.env.local
.env.*.local

# Vite 缓存
.vite/
vite.config.ts.timestamp-*

# TypeScript 构建缓存
*.tsbuildinfo
node_modules/.tmp/

# 编辑器
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 系统文件
.DS_Store
Thumbs.db
Desktop.ini

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
backend/logs/
!backend/logs/.gitkeep

# 运行时
pids/
*.pid
*.seed
*.pid.lock

# 测试覆盖率
coverage/
.nyc_output/

package-lock.json
**/package-lock.json
**/yarn.lock
**/yarn.lock
**/pnpm-lock.yaml
**/package-lock.json
**/node_modules/
**/dist/
**/build/
**/coverage/
**/logs/
**/pids/
**/*.log
**/*.pid
**/*.seed
**/*.pid.lock
**/*.suo
**/*.ntvs*
frontend/vite.config.ts